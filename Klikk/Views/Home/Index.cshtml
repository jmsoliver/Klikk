<!-- ========================================
     TRENDING PRODUCTS
======================================== -->

<section class="trending-section">

    <div class="container">

        <div class="section-header d-flex justify-content-between align-items-center">

            <div>

                <h2>
                    Trending Products
                </h2>

                <p>
                    Discover what shoppers love today
                </p>

            </div>

            <a asp-controller="Products"
               asp-action="Index"
               class="view-all-btn">

                View All

            </a>

        </div>

        <div class="row g-4 align-items-start">

            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">

                    <div class="shop-product-card clickable-card"
                         onclick="window.location='@Url.Action("Details", "Products", new { id = item.Id })'">

                        <!-- IMAGE -->

                        <div class="shop-product-image">

                            <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                 ? "https://via.placeholder.com/500x300"
                                                                 : item.ImageUrl)"
                                                                                                             alt="@item.Name">

                            <div class="product-overlay-buttons">

                                <a asp-controller="Products"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="overlay-btn"
                                   onclick="event.stopPropagation();">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a href="javascript:void(0);"
                                   class="overlay-btn add-to-cart-btn"
                                   data-product-id="@item.Id"
                                   onclick="event.stopPropagation();">

                                    <i class="bi bi-cart-plus"></i>

                                </a>

                            </div>

                        </div>

                        <!-- BODY -->

                        <div class="shop-product-body">

                            <span class="product-category">

                                @(item.Category?.Name ?? "General")

                            </span>

                            <h4>

                                @item.Name

                            </h4>

                            <p class="product-description-clamp">

                                @(string.IsNullOrEmpty(item.Description)
                                                            ? "No description available."
                                                            : item.Description)

                        </p>

                            <div class="shop-product-footer">

                                <div>

                                    <h5>

                                        ₱@item.Price

                                    </h5>

                                    <span>

                                        Stock: @item.StockQuantity

                                    </span>

                                </div>

                            </div>

                            <!-- HOVER ACTIONS -->

                            <div class="shop-hover-actions">

                                <a href="javascript:void(0);"
                                   class="shop-add-btn add-to-cart-btn"
                                   data-product-id="@item.Id"
                                   onclick="event.stopPropagation();">

                                    <i class="bi bi-cart-plus"></i>

                                    Add to Cart

                                </a>

                                <a asp-controller="Products"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="shop-buy-btn"
                                   onclick="event.stopPropagation();">

                                    <i class="bi bi-eye"></i>

                                    View Product

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
                        }
        </div>

    </div>

    <!-- AI CHAT -->

    <div id="chatButton">
        <i class="bi bi-chat-dots-fill"></i>
    </div>

    <div id="chatPanel">

        <div id="chatHeader">
            Klikk Assistant
            <button id="closeChat">&times;</button>
        </div>

        <div id="chatMessages"></div>

        <div id="chatInputArea">

            <input id="chatInput"
                   placeholder="Ask me anything..." />

            <button id="sendChat" title="Send message">
                <i class="bi bi-send-fill"></i>
            </button>

        </div>

    </div>

</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const buttons = document.querySelectorAll(".add-to-cart-btn");

        buttons.forEach(button => {

            button.addEventListener("click", async function (e) {

                e.preventDefault();
                e.stopPropagation();

                const productId = this.dataset.productId;

                try {

                    const response = await fetch(`/Cart/AddToCart?productId=${productId}`, {
                        method: "POST"
                    });

                    if (response.ok) {

                        const data = await response.json();

                            if (data.success) {

                                showToast("Product added to cart!");

                            } else {

                                showToast("Failed to add product.");

                            }

                        }
                        else {

                                showToast("Failed to add product.");
                        }

                } catch {

                    showToast("Please sign in first.");

                }

            });

        });

    });

    function showToast(message) {

        const toast = document.createElement("div");

        toast.className = "custom-toast";
        toast.innerText = message;

        document.body.appendChild(toast);

        setTimeout(() => {
            toast.classList.add("show");
        }, 100);

        setTimeout(() => {

            toast.classList.remove("show");

            setTimeout(() => {
                toast.remove();
            }, 300);

        }, 2500);

    }

        const chatButton =
        document.getElementById("chatButton");

    const chatPanel =
        document.getElementById("chatPanel");

    const closeChat =
        document.getElementById("closeChat");

        let welcomeShown = false;

        chatButton.onclick = () =>
    {
        chatPanel.style.display = "block";

        chatPanel.classList.remove("chat-closing");
        chatPanel.classList.add("chat-opening");

        if (!welcomeShown)
        {
            document.getElementById("chatMessages").innerHTML += `
            <div class="ai-msg">
                <div class="ai-msg-content">
                    👋 Hi! I'm your Klikk shopping assistant. I can help you find products, compare items, and answer questions about our store.
                </div>
            </div>`;

            welcomeShown = true;
        }
    };

        closeChat.onclick = () =>
    {
        chatPanel.classList.remove("chat-opening");
        chatPanel.classList.add("chat-closing");

        setTimeout(() =>
        {
            chatPanel.style.display = "none";
        }, 250);
    };

    document
    .getElementById("sendChat")
    .addEventListener("click", sendMessage);

    async function sendMessage()
    {
        const input =
            document.getElementById("chatInput");

        const message =
            input.value.trim();

        if(!message)
            return;

        const messages =
            document.getElementById("chatMessages");

        messages.innerHTML +=
    `<div class="user-msg">
        <div class="user-msg-content">${message}</div>
    </div>`;

        input.value = "";

        const response =
            await fetch("/AI/Ask",
        {
            method:"POST",

            headers:
            {
                "Content-Type":"application/json"
            },

            body: JSON.stringify(
            {
                message: message
            })
        });

            const text = await response.text();

    console.log("SERVER RESPONSE:");
    console.log(text);

    let data;

    try {
        data = JSON.parse(text);
    }
    catch {
        messages.innerHTML += `
            <div class="ai-msg">
        <div class="ai-msg-content">Invalid server response.</div>
    </div>`;
        return;
    }

        if (!data.choices) {
        messages.innerHTML +=
    `<div class="ai-msg">
        <div class="ai-msg-content">
            Sorry, I'm having trouble responding right now.
        </div>
    </div>`;

        console.log(data);

        return;
    }

    const reply =
    data.choices[0].message.content.trim();

        messages.innerHTML +=
    `<div class="ai-msg">
        <div class="ai-msg-content">
            ${reply}
        </div>
    </div>`;

        messages.scrollTop =
            messages.scrollHeight;
    }

</script>

<style>
    .ai-msg-content p,
    .ai-msg-content ul,
    .ai-msg-content ol {
        margin: 0;
        padding-left: 0;
    }

    #chatButton {
        position: fixed;
        bottom: 25px;
        right: 25px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FF6F4D 0%, #FF5733 100%);
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        z-index: 9999;
        font-size: 24px;
        box-shadow: 0 4px 16px rgba(255, 111, 77, 0.35);
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        border: none;
    }

        #chatButton:hover {
            transform: scale(1.12) translateY(-3px);
            box-shadow: 0 8px 28px rgba(255, 111, 77, 0.45);
        }

        #chatButton:active {
            transform: scale(0.95);
        }

    #chatPanel {
        position: fixed;
        bottom: 90px;
        right: 20px;
        width: 400px;
        height: 580px;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        display: none;
        z-index: 9999;
        border: none; /* remove border */
        box-shadow: 0 20px 60px rgba(0,0,0,.15), 0 0 0 1px rgba(0,0,0,.04);
    }

    @@keyframes slideUp {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@keyframes slideDown {
        from {
            opacity: 1;
            transform: translateY(0);
        }

        to {
            opacity: 0;
            transform: translateY(20px);
        }
    }

    .chat-opening {
        animation: slideUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .chat-closing {
        animation: slideDown 0.25s ease forwards;
    }

    #chatHeader {
        background: linear-gradient(135deg, #FF6F4D 0%, #FF5733 100%);
        color: white;
        padding: 20px 24px;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: .4px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: none;
        box-shadow: none;
        margin: 0;
    }

    #closeChat {
        border: none;
        background: none;
        color: white;
        font-size: 26px;
        cursor: pointer;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        border-radius: 8px;
    }

        #closeChat:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: rotate(90deg);
        }

    #chatMessages {
        height: 430px;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: linear-gradient(180deg, #fafafa 0%, #f5f5f5 100%);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

        #chatMessages::-webkit-scrollbar {
            width: 6px;
        }

        #chatMessages::-webkit-scrollbar-track {
            background: transparent;
        }

        #chatMessages::-webkit-scrollbar-thumb {
            background: rgba(255, 111, 77, 0.3);
            border-radius: 3px;
        }

            #chatMessages::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 111, 77, 0.5);
            }

    #chatInputArea {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 14px 16px;
        background: white;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
    }

    #chatInput {
        flex: 1;
        border: 1px solid #e5e5e5;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 14px;
        font-family: inherit;
        transition: all 0.2s ease;
        outline: none;
    }

        #chatInput:focus {
            border-color: #FF6F4D;
            box-shadow: 0 0 0 3px rgba(255, 111, 77, 0.08);
        }

        #chatInput::placeholder {
            color: #999;
        }

    #sendChat {
        border: none;
        background: linear-gradient(135deg, #FF6F4D 0%, #FF5733 100%);
        color: white;
        width: 36px;
        height: 36px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        font-size: 16px;
    }

        #sendChat:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(255, 111, 77, 0.3);
        }

        #sendChat:active {
            transform: scale(0.95);
        }

    .user-msg {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 4px;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .user-msg-content {
        background: linear-gradient(135deg, #FF6F4D 0%, #FF5733 100%);
        color: white;
        padding: 12px 16px;
        border-radius: 18px 18px 6px 18px;
        max-width: 75%;
        word-wrap: break-word;
        font-size: 14px;
        line-height: 1.4;
        box-shadow: 0 2px 8px rgba(255, 111, 77, 0.2);
    }

    .ai-msg {
        display: flex;
        justify-content: flex-start;
        margin-bottom: 4px;
        animation: fadeIn 0.3s ease;
    }

    .ai-msg-content {
        background: #ffffff;
        color: #2d3748;
        padding: 12px 16px;
        margin: 0;
        border-radius: 18px 18px 18px 6px;
        max-width: 82%;
        word-wrap: break-word;
        white-space: normal;
        font-size: 14px;
        line-height: 1.6;
        border: 1px solid #f0f0f0;
        box-shadow: 0 3px 12px rgba(0,0,0,.06);
    }

        .ai-msg-content b {
            color: #FF6F4D;
            font-weight: 600;
            display: none;
        }

    .typing-indicator {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 10px 16px;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 16px 16px 16px 4px;
        width: fit-content;
    }

    .typing-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #FF6F4D;
        animation: typing 1.4s infinite;
    }

        .typing-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    @@keyframes typing {
        0%, 60%, 100%

    {
        opacity: 0.4;
        transform: translateY(0);
    }

    30% {
        opacity: 1;
        transform: translateY(-8px);
    }

    }

    .trending-section .shop-product-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .trending-section .shop-product-card:hover {
            transform: translateY(-8px) !important;
            z-index: 2;
        }

            .trending-section .shop-product-card:hover ~ .shop-product-card {
                transform: none !important;
            }

    .trending-section .product-description-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        min-height: 72px;
        line-height: 1.5;
    }

    .trending-section .shop-product-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .trending-section .shop-product-card:hover {
            transform: translateY(-8px) !important;
            z-index: 2;
        }

            .trending-section .shop-product-card:hover ~ .shop-product-card {
                transform: none !important;
            }

    .trending-section .product-description-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        min-height: 72px;
        line-height: 1.5;
    }
</style>