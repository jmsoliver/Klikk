@model List<Klikk.Models.Product>

@{
    ViewData["Title"] = "Home";
}

<!-- ========================================
     HERO SECTION
======================================== -->

<section class="hero-section">

    <div class="container">

        <div class="row g-4 align-items-stretch">

            <!-- MAIN HERO -->

            <div class="col-lg-8">

                <div class="hero-main" style="background-image: url('@Url.Content("~/images/banner1.png")'); background-size: cover; background-position: center;">
                    <div class="hero-content">

                        <span class="hero-badge">

                            ✨ Modern Shopping Experience

                        </span>

                        <h1>

                            Shop Smarter <br />
                            with <span>Klikk</span>

                        </h1>

                        <p>

                            Discover trending products,
                            premium essentials, and modern
                            ecommerce convenience all in one place.

                        </p>

                        <div class="hero-buttons">

                            <a asp-controller="Products"
                               asp-action="Index"
                               class="btn klikk-btn-primary btn-lg d-inline-flex align-items-center justify-content-center">

                                Shop Now

                            </a>

                            <a asp-controller="Products"
                               asp-action="Index"
                               class="btn hero-secondary-btn btn-lg">

                                Explore Products

                            </a>

                        </div>

                    </div>

                </div>

            </div>

            <!-- SIDE PROMOS -->

            <div class="col-lg-4">

                <div class="promo-column">

                    <div class="promo-card mint-card" style="background-image: url('@Url.Content("~/images/banner2.png")'); background-size: cover; background-position: center;">
