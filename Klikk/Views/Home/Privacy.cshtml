@{
    ViewData["Title"] = "Privacy Policy";
}

<!-- ========================================
     PRIVACY HERO
======================================== -->

<section class="privacy-hero">

    <div class="container">

        <div class="privacy-hero-card">

            <span class="privacy-badge">

                🔒 Your Privacy Matters

            </span>

            <h1>

                Privacy Policy

            </h1>

            <p>

                At Klikk, we value transparency,
                security, and your trust. This page
                explains how we collect, use, and
                protect your information while you
                shop with us.

            </p>

        </div>

    </div>

</section>

<!-- ========================================
     PRIVACY CONTENT
======================================== -->

<section class="privacy-section">

    <div class="container">

        <div class="row g-4">

            <!-- LEFT CONTENT -->

            <div class="col-lg-8">

                <div class="privacy-card">

                    <h3>
                        Information We Collect
                    </h3>

                    <p>

                        Klikk may collect personal information
                        such as your name, email address,
                        shipping details, and payment-related
                        information when you create an account
                        or place an order.

                    </p>

                    <p>

                        We also collect non-personal data such
                        as browser type, device information,
                        and usage analytics to improve the
                        shopping experience.

                    </p>

                </div>

                <div class="privacy-card">

                    <h3>
                        How We Use Your Data
                    </h3>

                    <p>

                        Your information is used to:

                    </p>

                    <ul class="privacy-list">

                        <li>
                            Process and manage orders
                        </li>

                        <li>
                            Improve our platform and services
                        </li>

                        <li>
                            Provide customer support
                        </li>

                        <li>
                            Send order updates and notifications
                        </li>

                        <li>
                            Enhance security and fraud prevention
                        </li>

                    </ul>

                </div>

                <div class="privacy-card">

                    <h3>
                        Security & Protection
                    </h3>

                    <p>

                        Klikk uses secure technologies,
                        encrypted transactions, and
                        protected authentication systems
                        to safeguard your data.

                    </p>

                    <p>

                        We continuously monitor and improve
                        our systems to maintain a safe
                        ecommerce experience for all users.

                    </p>

                </div>

                <div class="privacy-card">

                    <h3>
                        Cookies & Analytics
                    </h3>

                    <p>

                        We may use cookies and analytics
                        tools to personalize your shopping
                        experience, remember preferences,
                        and understand platform usage trends.

                    </p>

                </div>

            </div>

            <!-- RIGHT SIDEBAR -->

            <div class="col-lg-4">

                <div class="privacy-side-card">

                    <div class="privacy-side-icon">

                        <i class="bi bi-shield-lock"></i>

                    </div>

                    <h4>
                        Secure Shopping
                    </h4>

                    <p>

                        Your personal data and
                        transactions are protected
                        with modern security practices.

                    </p>

                </div>

                <div class="privacy-side-card mint-side">

                    <div class="privacy-side-icon">

                        <i class="bi bi-check-circle"></i>

                    </div>

                    <h4>
                        Transparent Policies
                    </h4>

                    <p>

                        We believe in honest,
                        clear, and user-friendly
                        privacy practices.

                    </p>

                </div>

                <div class="privacy-side-card yellow-side">

                    <div class="privacy-side-icon">

                        <i class="bi bi-headset"></i>

                    </div>

                    <h4>
                        Need Help?
                    </h4>

                    <p>

                        Contact our support team
                        anytime for privacy or
                        account concerns.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>