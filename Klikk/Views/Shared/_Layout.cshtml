<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Klikk</title>

    <!-- GOOGLE FONT -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <!-- BOOTSTRAP ICONS -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- BOOTSTRAP -->

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- SITE CSS -->

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/Klikk.styles.css"
          asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->

    <header class="klikk-header-sticky">

        <nav class="navbar navbar-expand-lg klikk-navbar">

            <div class="container">

                <!-- LOGO -->

                <a class="navbar-brand klikk-logo"
                   asp-controller="Home"
                   asp-action="Index">

                    <!-- REPLACE WITH LOGO IMAGE LATER -->

                    <span class="logo-text">
                        Klikk
                    </span>

                </a>

                <!-- MOBILE TOGGLE -->

                <button class="navbar-toggler border-0 shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMain">

                    <i class="bi bi-list fs-2"></i>

                </button>

                <!-- NAV CONTENT -->

                <div class="collapse navbar-collapse"
                     id="navbarMain">

                    <!-- SEARCH BAR -->

                    <form class="d-flex mx-lg-4 my-3 my-lg-0 flex-grow-1">

                        <div class="klikk-search-wrapper">

                            <i class="bi bi-search"></i>

                            <input class="form-control"
                                   type="search"
                                   placeholder="Search products, brands, categories..." />

                        </div>

                    </form>

                    <!-- NAV LINKS -->

                    <ul class="navbar-nav align-items-lg-center gap-lg-2">

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- ADMIN NAV ONLY -->

                            <li class="nav-item">

                                <a class="nav-link text-warning fw-semibold"
                                   asp-controller="Admin"
                                   asp-action="Index">

                                    Dashboard

                                </a>

                            </li>

                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle text-warning fw-semibold"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    Products

                                </a>

                                <ul class="dropdown-menu border-0 shadow">

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Products"
                                           asp-action="AdminIndex">

                                            Manage Products

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Products"
                                           asp-action="Create">

                                            Add Product

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }
         
                        <!-- AUTH SECTION (UNCHANGED) -->
                        @if (!User.IsInRole("Admin"))
                        {
                            <!-- USER NAVIGATION -->

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Home
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Products"
                                   asp-action="Index">
                                    Shop
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Wishlist"
                                   asp-action="Index">
                                    Favorites
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Cart"
                                   asp-action="Index">
                                    Cart
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Orders"
                                   asp-action="MyOrders">
                                    Orders
                                </a>
                            </li>
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown ms-lg-2">

                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    <i class="bi bi-person-circle me-1"></i>

                                    @User.Identity.Name

                                </a>

                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg">

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Profile"
                                           asp-action="Index">
                                            My Profile
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-area="Identity"
                                           asp-page="/Account/Manage/Index">
                                            Account Settings
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider"></li>

                                    <li>

                                        <form class="dropdown-item p-0"
                                              asp-area="Identity"
                                              asp-page="/Account/Logout"
                                              method="post">

                                            <button type="submit"
                                                    class="btn btn-link text-decoration-none text-dark w-100 text-start px-3 py-2">

                                                Logout

                                            </button>

                                        </form>

                                    </li>

                                </ul>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2">

                                <a class="btn klikk-btn-outline"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">

                                    Login

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="btn klikk-btn-primary"
                                   asp-area="Identity"
                                   asp-page="/Account/Register">

                                    Register

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- ALERTS -->
    @if (TempData["Success"] != null)
    {
        <div class="container mt-4">

            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0">

                @TempData["Success"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>

        </div>
    }

    <!-- MAIN -->

    <main role="main">

        @RenderBody()

    </main>

    <!-- FOOTER -->

    <footer class="klikk-footer">

        <div class="container">

            <div class="row g-4">

                <div class="col-lg-4">

                    <h3 class="footer-logo">
                        Klikk
                    </h3>

                    <p class="footer-text">

                        Shop it. Love it. Klikk it.

                    </p>

                </div>

                <div class="col-lg-4">

                    <h6 class="footer-title">
                        Quick Links
                    </h6>

                    <ul class="footer-links">

                        <li>
                            <a asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Products"
                               asp-action="Index">
                                Shop
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Cart"
                               asp-action="Index">
                                Cart
                            </a>
                        </li>

                    </ul>

                </div>

                <div class="col-lg-4">

                    <h6 class="footer-title">
                        Support
                    </h6>

                    <p class="footer-text">

                        Fast checkout, secure shopping,
                        and modern ecommerce convenience.

                    </p>

                </div>

            </div>

            <hr class="footer-divider">

            <div class="text-center footer-bottom">

                © 2026 Klikk. All rights reserved.

            </div>

        </div>

    </footer>

    <!-- SCRIPTS -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>