@model Klikk.Models.Product

@{
    ViewData["Title"] = "Product Details";
    var suggestions = ViewBag.SuggestedProducts as List<Klikk.Models.Product>;
}

<!-- ========================================
     PRODUCT HERO
======================================== -->

<section class="product-hero-section">

    <div class="container">

        <div class="row g-5 align-items-start">

            <!-- PRODUCT IMAGE -->

            <div class="col-lg-6">

                @{
                    var allImages = new List<string>();

                    if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        allImages.Add(Model.ImageUrl);
                    }

                    if (Model.GalleryImages != null && Model.GalleryImages.Any())
                    {
                        allImages.AddRange(
                        Model.GalleryImages
                        .Where(g => !string.IsNullOrEmpty(g.ImageUrl))
                        .Select(g => g.ImageUrl)
                        );
                    }

                    if (!allImages.Any())
                    {
                        allImages.Add("https://via.placeholder.com/700x650");
                    }
                }

                <div class="product-image-wrapper">

                    <div class="product-image-card">

                        <div class="product-image-slider">

                            @for (int i = 0; i < allImages.Count; i++)
                            {
                                <img src="@allImages[i]"
                                     alt="@Model.Name"
                                     class="slider-image @(i == 0 ? "active" : "")"
                                     data-index="@i" />
                            }

                        </div>

                        <!-- IMAGE DOTS -->

                        <div class="slider-dots">

                            @for (int i = 0; i < allImages.Count; i++)
                            {
                                <button type="button"
                                        class="slider-dot @(i == 0 ? "active" : "")"
                                        onclick="goToSlide(@i)">
                                </button>
                            }

                        </div>

                    </div>

                    <!-- THUMBNAILS -->

                    <div class="product-gallery-thumbnails">

                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <img src="@allImages[i]"
                                 class="gallery-thumb @(i == 0 ? "active-thumb" : "")"
                                 onclick="goToSlide(@i)" />
                        }

                    </div>

                </div>

            </div>

            <!-- PRODUCT INFO -->

            <div class="col-lg-6">

                <div class="product-info-container">

                    <span class="product-category">
                        @Model.Category?.Name
                    </span>

                    <!-- TITLE NOW MORE ALIGNED WITH IMAGE -->

                    <h1 class="product-title">
                        @Model.Name
                    </h1>

                    <!-- DESCRIPTION BOX -->

                    <div class="product-description-box">

                        <p class="product-description collapsed"
                           id="productDescription">

                            @Model.Description

                        </p>

                        @if (!string.IsNullOrEmpty(Model.Description) && Model.Description.Length > 220)
                        {
                            <button type="button"
                                    class="see-more-btn"
                                    id="seeMoreBtn">

                                See More

                            </button>
                        }

                    </div>

                    <!-- PRICE CARD -->

                    <div class="product-price-card">

                        <div>

                            <h2>
                                ₱@Model.Price
                            </h2>

                            <span class="stock-status">
                                @(Model.StockQuantity > 0 ? "In Stock" : "Out of Stock")
                            </span>

                        </div>

                        <div class="stock-pill">
                            @Model.StockQuantity left
                        </div>

                    </div>

                    <!-- FEATURES -->

                    <div class="product-feature-list">

                        <div class="feature-pill">
                            <i class="bi bi-truck"></i>
                            Free Shipping
                        </div>

                        <div class="feature-pill">
                            <i class="bi bi-shield-check"></i>
                            Secure Checkout
                        </div>

                        <div class="feature-pill">
                            <i class="bi bi-arrow-repeat"></i>
                            Easy Returns
                        </div>

                    </div>

                    <!-- ACTION BUTTONS -->

                    <div class="product-actions">

                        <!-- ADD TO CART -->

                        <a href="javascript:void(0);"
                           class="btn klikk-btn-primary btn-lg action-btn add-to-cart-btn"
                           data-product-id="@Model.Id">

                            <i class="bi bi-cart-plus"></i>
                            <span>Add to Cart</span>

                        </a>

                        <!-- BUY NOW -->

                        <a asp-controller="Orders"
                           asp-action="BuyNow"
                           asp-route-productId="@Model.Id"
                           class="btn btn-dark btn-lg action-btn">

                            <i class="bi bi-lightning-charge-fill"></i>
                            <span>Buy Now</span>

                        </a>

                        <!-- WISHLIST -->

                        <a asp-controller="Wishlist"
                           asp-action="Add"
                           asp-route-productId="@Model.Id"
                           class="btn hero-secondary-btn btn-lg action-btn"
                           style="background-color: #ff4d6d; color: white; border-color: #ff4d6d;">

                            <i class="bi bi-heart"></i>
                            <span>Wishlist</span>

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ========================================
     DESCRIPTION MODAL
======================================== -->

<div class="description-modal-overlay"
     id="descriptionModal">

    <div class="description-modal-box">

        <button class="description-modal-close"
                id="closeDescriptionModal">

            <i class="bi bi-x-lg"></i>

        </button>

        <h3>
            Product Description
        </h3>

        <div class="description-modal-content">

            @Model.Description

        </div>

    </div>

</div>

<!-- ========================================
     REVIEWS SECTION
======================================== -->

<section class="review-section">

    <div class="container">

        <div class="section-header">

            <h2>
                Customer Reviews
            </h2>

            <p>
                Trusted feedback from verified customers
            </p>

        </div>

        @if (User.Identity.IsAuthenticated)
        {
            <div class="review-form-card mb-5">

                <form asp-controller="Reviews"
                      asp-action="Create"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="productId"
                           value="@Model.Id" />

                    <label class="review-label">
                        Your Rating
                    </label>

                    <div class="star-rating mb-4">

                        <input type="radio" id="5-stars" name="Rating" value="5" />
                        <label for="5-stars">★</label>

                        <input type="radio" id="4-stars" name="Rating" value="4" />
                        <label for="4-stars">★</label>

                        <input type="radio" id="3-stars" name="Rating" value="3" />
                        <label for="3-stars">★</label>

                        <input type="radio" id="2-stars" name="Rating" value="2" />
                        <label for="2-stars">★</label>

                        <input type="radio" id="1-star" name="Rating" value="1" />
                        <label for="1-star">★</label>

                    </div>

                    <textarea name="Comment"
                          class="form-control review-textarea"
                          rows="5"
                          placeholder="Share your experience with this product. Talk about the quality, packaging, delivery, or overall satisfaction."
                          required></textarea>

                    <button type="submit"
                            class="btn klikk-btn-primary review-submit-btn mt-4">

                        Submit Review

                    </button>

                </form>

            </div>
        }

        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            <div class="row g-4">

                @foreach (var review in Model.Reviews.OrderByDescending(r => r.ReviewDate))
                {
                    <div class="col-md-6">

                        <div class="review-card">

                            <!-- REVIEW HEADER -->

                            <div class="review-header">

                                <div class="review-user">

                                    <div class="review-avatar">

                                        <i class="bi bi-person-fill"></i>

                                    </div>

                                    <div class="review-user-info">

                                        <h6>
                                            @(review.User?.UserName ?? "Anonymous User")
                                        </h6>

                                        <small class="review-date">
                                            @review.ReviewDate.ToString("MMM dd, yyyy")
                                        </small>

                                    </div>

                                </div>

                                <div class="review-stars">

                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="@(i <= review.Rating ? "text-warning" : "text-muted")">★</span>
                                    }

                                </div>

                            </div>

                            <!-- REVIEW CONTENT -->

                            <div class="review-content">

                                <p>
                                    @review.Comment
                                </p>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="empty-review-state">

                <i class="bi bi-chat-square-text"></i>

                <h5>
                    No reviews yet
                </h5>

                <p>
                    Be the first to review this product.
                </p>

            </div>
        }

    </div>

</section>

<style>

    /* ========================================
           PRODUCT PAGE
        ======================================== */

    .product-hero-section {
        padding: 48px 0 42px;
        background: #fafafa;
    }

    .product-info-container {
        padding-top: 0;
    }

    .product-image-wrapper {
        position: relative;
    }

    .product-image-card {
        position: relative;
        background: #fff;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 14px 35px rgba(0,0,0,0.07);
        height: 500px;
    }

    .product-image-slider {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .slider-image {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        opacity: 0;
        transition: opacity 0.35s ease-in-out;
        pointer-events: none;
        background: #fff;
        padding: 0;
        margin: 0;
        border: none;
    }

        .slider-image.active {
            opacity: 1;
            pointer-events: auto;
            z-index: 2;
        }

    .slider-dots {
        position: absolute;
        left: 50%;
        bottom: 22px;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 12px;
        z-index: 5;
        background: rgba(255,255,255,0.75);
        backdrop-filter: blur(10px);
        padding: 10px 16px;
        border-radius: 999px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .slider-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        border: none;
        background: rgba(0,0,0,0.18);
        transition: all 0.28s ease;
        padding: 0;
    }

        .slider-dot.active {
            width: 30px;
            background: #111;
            transform: none;
        }

    .product-gallery-thumbnails {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        flex-wrap: wrap;
    }

    .gallery-thumb {
        width: 72px;
        height: 72px;
        object-fit: contain;
        border-radius: 16px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.25s ease;
        background: #fff;
        padding: 6px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.05);
    }

        .gallery-thumb:hover {
            border-color: rgba(0,0,0,0.15);
            transform: translateY(-3px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.10);
        }

        .gallery-thumb.active-thumb {
            border-color: #111;
            background: #f8f8f8;
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(0,0,0,0.12);
        }

    .product-floating-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 2;
        background: #111;
        color: #fff;
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .product-category {
        background: #fff;
        padding: 7px 14px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 14px;
        letter-spacing: 0.4px;
    }

    /* TITLE MOVED HIGHER BUT LOWER ALIGNED */

    .product-title {
        font-size: 2.35rem;
        font-weight: 800;
        line-height: 1.08;
        color: #111;
        margin-top: 4px;
        margin-bottom: 18px;
        letter-spacing: -1.2px;
    }

    /* DESCRIPTION FIXED SIZE */

    .product-description-box {
        background: #fff;
        border-radius: 20px;
        padding: 20px;
        min-height: 145px;
        max-height: 145px;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 6px 18px rgba(0,0,0,0.04);
        margin-bottom: 18px;
    }

    .product-description {
        font-size: 0.95rem;
        line-height: 1.7;
        color: #666;
        margin: 0;
    }

        .product-description.collapsed {
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

    .see-more-btn {
        position: absolute;
        bottom: 18px;
        right: 18px;
        border: none;
        background: #111;
        color: #fff;
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        transition: 0.2s ease;
    }

        .see-more-btn:hover {
            transform: translateY(-2px);
            background: #000;
        }

    /* PRICE CARD */

    .product-price-card {
        background: #fff;
        border-radius: 20px;
        padding: 20px 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 8px 24px rgba(0,0,0,0.05);
        border: 1px solid rgba(0,0,0,0.05);
        margin-bottom: 18px;
    }

        .product-price-card h2 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 2px;
        }

    .stock-status {
        color: #777;
        font-weight: 600;
    }

    .stock-pill {
        background: #f5f5f5;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.9rem;
        color: #444;
    }

    /* FEATURES */

    .product-feature-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 18px;
        width: 100%;
    }

    .feature-pill {
        background: #fff;
        min-height: 72px;
        padding: 12px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 0.85rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-align: center;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 5px 14px rgba(0,0,0,0.04);
        width: 100%;
    }

        .feature-pill i {
            font-size: 1.2rem;
        }

    /* ACTION BUTTONS */

    .product-actions {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        width: 100%;
    }

    .action-btn {
        width: 100%;
        min-width: unset;
        height: 52px;
        border-radius: 15px;
        font-size: 0.92rem;
        font-weight: 700;
        display: flex !important;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.25s ease;
        padding: 0 14px;
    }

        .action-btn i {
            font-size: 1.05rem;
        }

        .action-btn:hover {
            transform: translateY(-2px);
        }


    /* MODAL */

    .description-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.65);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition: 0.25s ease;
        padding: 20px;
    }

        .description-modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

    .description-modal-box {
        background: #fff;
        width: 100%;
        max-width: 720px;
        border-radius: 28px;
        padding: 35px;
        position: relative;
        animation: modalPop 0.25s ease;
    }

    @@keyframes modalPop {

        from {
            transform: scale(0.92);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .description-modal-close {
        position: absolute;
        top: 18px;
        right: 18px;
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        background: #f2f2f2;
        font-size: 16px;
    }

    .description-modal-box h3 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 24px;
    }

    .description-modal-content {
        color: #555;
        line-height: 2;
        max-height: 60vh;
        overflow-y: auto;
        padding-right: 10px;
    }

    /* REVIEWS */

    .review-section {
        padding: 90px 0;
        background: #fff;
    }

    .section-header {
        text-align: center;
        margin-bottom: 50px;
    }

        .section-header h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 12px;
        }

        .section-header p {
            color: #777;
            font-size: 1.05rem;
        }

    /* ========================================
       REVIEW CARD
    ======================================== */

    .review-card {
        background: #fff;
        border-radius: 24px;
        padding: 26px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 10px 28px rgba(0,0,0,0.05);
        height: 100%;
        transition: all 0.25s ease;
    }

        .review-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 40px rgba(0,0,0,0.08);
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 20px;
    }

    .review-user {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .review-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #ff613a;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.45rem;
        flex-shrink: 0;
    }

    .review-user-info h6 {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        color: #111;
    }

    .review-date {
        color: #888;
        font-size: 0.82rem;
    }

    .review-stars {
        display: flex;
        align-items: center;
        gap: 2px;
        font-size: 2rem;
        flex-shrink: 0;
    }

    .review-content {
        background: #f8f9fb;
        border-radius: 18px;
        padding: 20px;
        border: 1px solid rgba(0,0,0,0.04);
    }

        .review-content p {
            margin: 0;
            color: #444;
            line-height: 1.85;
            font-size: 0.95rem;
        }

    /* MOBILE */

    @@media (max-width: 576px) {

        .review-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .review-stars {
            margin-left: 66px;
        }
    }
    /* TOAST */

    .custom-toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #111;
        color: #fff;
        padding: 14px 22px;
        border-radius: 14px;
        z-index: 9999;
        opacity: 0;
        transform: translateY(20px);
        transition: 0.3s ease;
        font-weight: 600;
    }

        .custom-toast.show {
            opacity: 1;
            transform: translateY(0);
        }

    /* MOBILE */

    @@media (max-width: 768px) {

        .product-title {
            font-size: 2.2rem;
        }

        .product-price-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }

        .action-btn {
            width: 100%;
        }

        .product-image-card {
            height: 340px;
        }

        .product-description-box {
            min-height: 210px;
            max-height: 210px;
        }

        .product-feature-list {
            grid-template-columns: 1fr;
        }

        .product-actions {
            grid-template-columns: 1fr;
        }
    }

</style>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        // ========================================
        // ADD TO CART
        // ========================================

        const buttons = document.querySelectorAll(".add-to-cart-btn");

        buttons.forEach(button => {

            button.addEventListener("click", async function (e) {

                e.preventDefault();

                const productId = this.dataset.productId;

                try {

                    const response = await fetch(`/Cart/AddToCart?productId=${productId}`, {
                        method: "POST"
                    });

                    if (response.ok) {

                        const data = await response.json();

                            if (data.success) {

                                showToast("Product added to cart!");

                            } else {

                                showToast("Failed to add product.");

                            }

                        }
                        else {

                                showToast("Failed to add product.");
                        }

                } catch {

                    showToast("Please sign in first.");

                }

            });

        });

        // ========================================
        // DESCRIPTION MODAL
        // ========================================

        const seeMoreBtn = document.getElementById("seeMoreBtn");
        const modal = document.getElementById("descriptionModal");
        const closeModal = document.getElementById("closeDescriptionModal");

        if (seeMoreBtn) {

            seeMoreBtn.addEventListener("click", function () {

                modal.classList.add("active");
                document.body.style.overflow = "hidden";

            });

        }

        if (closeModal) {

            closeModal.addEventListener("click", function () {

                modal.classList.remove("active");
                document.body.style.overflow = "auto";

            });

        }

        if (modal) {

            modal.addEventListener("click", function (e) {

                if (e.target === modal) {

                    modal.classList.remove("active");
                    document.body.style.overflow = "auto";

                }

            });

        }

                // ========================================
        // AUTO IMAGE SLIDER
        // ========================================

        const totalSlides =
            document.querySelectorAll(".slider-image").length;

        if (totalSlides > 1) {

            setInterval(() => {

                let nextSlide = currentSlide + 1;

                if (nextSlide >= totalSlides) {
                    nextSlide = 0;
                }

                goToSlide(nextSlide);

            }, 4000);

        }

    });

            let currentSlide = 0;

    function goToSlide(index) {

        const slides =
            document.querySelectorAll(".slider-image");

        const dots =
            document.querySelectorAll(".slider-dot");

        const thumbs =
            document.querySelectorAll(".gallery-thumb");

        slides.forEach(slide => {
            slide.classList.remove("active");
        });

        dots.forEach(dot => {
            dot.classList.remove("active");
        });

        thumbs.forEach(thumb => {
            thumb.classList.remove("active-thumb");
        });

        slides[index].classList.add("active");
        dots[index].classList.add("active");
        thumbs[index].classList.add("active-thumb");

        currentSlide = index;
    }

    function showToast(message) {

        const toast = document.createElement("div");

        toast.className = "custom-toast";
        toast.innerText = message;

        document.body.appendChild(toast);

        setTimeout(() => {
            toast.classList.add("show");
        }, 100);

        setTimeout(() => {

            toast.classList.remove("show");

            setTimeout(() => {
                toast.remove();
            }, 300);

        }, 2500);

    }

</script>