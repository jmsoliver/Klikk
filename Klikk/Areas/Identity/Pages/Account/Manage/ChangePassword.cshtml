@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="account-card">

    <div class="account-card-header">

        <span class="account-badge">
            Security Settings
        </span>

        <h2>
            Change Password
        </h2>

        <p>
            Keep your Klikk account secure by updating your password regularly.
        </p>

    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="change-password-form"
          method="post"
          class="account-form">

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger"
             role="alert">
        </div>

        <!-- CURRENT PASSWORD -->

        <div class="auth-input-group">

            <label asp-for="Input.OldPassword">
                Current Password
            </label>

            <div class="password-input-wrapper">

                <input asp-for="Input.OldPassword"
                       class="form-control auth-input"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="Enter your current password" />

                <i class="bi bi-lock password-input-icon"></i>

            </div>

            <span asp-validation-for="Input.OldPassword"
                  class="text-danger">
            </span>

        </div>

        <!-- NEW PASSWORD -->

        <div class="auth-input-group">

            <label asp-for="Input.NewPassword">
                New Password
            </label>

            <div class="password-input-wrapper">

                <input asp-for="Input.NewPassword"
                       class="form-control auth-input"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="Enter your new password" />

                <i class="bi bi-shield-lock password-input-icon"></i>

            </div>

            <span asp-validation-for="Input.NewPassword"
                  class="text-danger">
            </span>

        </div>

        <!-- CONFIRM PASSWORD -->

        <div class="auth-input-group">

            <label asp-for="Input.ConfirmPassword">
                Confirm New Password
            </label>

            <div class="password-input-wrapper">

                <input asp-for="Input.ConfirmPassword"
                       class="form-control auth-input"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="Confirm your new password" />

                <i class="bi bi-check-circle password-input-icon"></i>

            </div>

            <span asp-validation-for="Input.ConfirmPassword"
                  class="text-danger">
            </span>

        </div>

        <!-- PASSWORD INFO -->

        <div class="password-info-box">

            <div class="password-info-icon">
                <i class="bi bi-info-circle"></i>
            </div>

            <div>

                <h6>
                    Password Security Tips
                </h6>

                <p>
                    Use a strong password with a mix of letters,
                    numbers, and symbols for better security.
                </p>

            </div>

        </div>

        <!-- BUTTON -->

        <button type="submit"
                class="btn auth-submit-btn">

            Update Password

        </button>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}