@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Forgot Password";
}

<!-- ========================================
     AUTH PAGE
======================================== -->

<section class="auth-section">

    <div class="container">

        <div class="auth-wrapper">

            <div class="row g-0">

                <!-- LEFT SIDE -->

                <div class="col-lg-6">

                    <div class="auth-brand-side">

                        <span class="auth-badge">

                            Password Recovery 🔐

                        </span>

                        <h1>

                            Recover your <span>Klikk</span> account

                        </h1>

                        <p>

                            Forgot your password?
                            No worries — enter your email
                            and we’ll help you securely
                            reset your account access.

                        </p>

                        <div class="auth-features">

                            <div class="auth-feature-item">

                                <i class="bi bi-shield-lock"></i>

                                <span>
                                    Secure Account Recovery
                                </span>

                            </div>

                            <div class="auth-feature-item">

                                <i class="bi bi-envelope-check"></i>

                                <span>
                                    Email Verification Support
                                </span>

                            </div>

                            <div class="auth-feature-item">

                                <i class="bi bi-arrow-repeat"></i>

                                <span>
                                    Fast Password Reset Process
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- RIGHT SIDE -->

                <div class="col-lg-6">

                    <div class="auth-form-side">

                        <div class="auth-form-wrapper">

                            <h2>

                                Forgot Password

                            </h2>

                            <p class="auth-subtitle">

                                Enter your email address below
                                to receive password reset instructions.

                            </p>

                            <form method="post">

                                <div asp-validation-summary="ModelOnly"
                                     class="alert alert-danger"
                                     role="alert">
                                </div>

                                <!-- EMAIL -->

                                <div class="auth-input-group">

                                    <label asp-for="Input.Email">

                                        Email Address

                                    </label>

                                    <input asp-for="Input.Email"
                                           class="form-control auth-input"
                                           autocomplete="username"
                                           placeholder="name@example.com" />

                                    <span asp-validation-for="Input.Email"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- BUTTON -->

                                <button type="submit"
                                        class="btn auth-submit-btn">

                                    Send Reset Link

                                </button>

                                <!-- LINKS -->

                                <div class="auth-links">

                                    <a asp-page="./Login">

                                        Back to Login

                                    </a>

                                    <a asp-page="./Register">

                                        Create New Account

                                    </a>

                                </div>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}