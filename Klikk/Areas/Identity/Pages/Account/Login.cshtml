@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<!-- ========================================
     AUTH PAGE
======================================== -->

<section class="auth-section">

    <div class="container">

        <div class="auth-wrapper">

            <div class="row g-0">

                <!-- LEFT SIDE -->

                <div class="col-lg-6">

                    <div class="auth-brand-side">

                        <span class="auth-badge">

                            Welcome Back 👋

                        </span>

                        <h1>

                            Login to <span>Klikk</span>

                        </h1>

                        <p>

                            Continue your modern shopping
                            experience with secure login,
                            smooth checkout, and personalized features.

                        </p>

                        <div class="auth-features">

                            <div class="auth-feature-item">

                                <i class="bi bi-bag-check"></i>

                                <span>
                                    Fast Checkout Experience
                                </span>

                            </div>

                            <div class="auth-feature-item">

                                <i class="bi bi-heart"></i>

                                <span>
                                    Wishlist & Saved Products
                                </span>

                            </div>

                            <div class="auth-feature-item">

                                <i class="bi bi-box-seam"></i>

                                <span>
                                    Track Orders Anytime
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- RIGHT SIDE -->

                <div class="col-lg-6">

                    <div class="auth-form-side">

                        <div class="auth-form-wrapper">

                            <h2>

                                Sign In

                            </h2>

                            <p class="auth-subtitle">

                                Enter your account credentials below.

                            </p>

                            <form id="account"
                                  method="post">

                                <div asp-validation-summary="ModelOnly"
                                     class="alert alert-danger"
                                     role="alert">
                                </div>

                                <!-- EMAIL -->

                                <div class="auth-input-group">

                                    <label asp-for="Input.Email">

                                        Email Address

                                    </label>

                                    <input asp-for="Input.Email"
                                           class="form-control auth-input"
                                           autocomplete="username"
                                           placeholder="name@example.com" />

                                    <span asp-validation-for="Input.Email"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- PASSWORD -->

                                <div class="auth-input-group">

                                    <label asp-for="Input.Password">

                                        Password

                                    </label>

                                    <input asp-for="Input.Password"
                                           class="form-control auth-input"
                                           autocomplete="current-password"
                                           placeholder="Enter your password" />

                                    <span asp-validation-for="Input.Password"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- REMEMBER -->

                                <div class="auth-remember">

                                    <label asp-for="Input.RememberMe"
                                           class="form-check-label">

                                        <input class="form-check-input"
                                               asp-for="Input.RememberMe" />

                                        Remember Me

                                    </label>

                                </div>

                                <!-- BUTTON -->

                                <button id="login-submit"
                                        type="submit"
                                        class="btn auth-submit-btn">

                                    Login to Klikk

                                </button>

                                <!-- LINKS -->

                                <div class="auth-links">

                                    <a id="forgot-password"
                                       asp-page="./ForgotPassword">

                                        Forgot Password?

                                    </a>

                                    <a asp-page="./Register"
                                       asp-route-returnUrl="@Model.ReturnUrl">

                                        Create Account

                                    </a>

                                </div>

                            </form>

                            <!-- EXTERNAL LOGIN -->
                            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                            {
                                <div class="auth-divider">

                                    <span>

                                        OR CONTINUE WITH

                                    </span>

                                </div>

                                <form id="external-account"
                                      asp-page="./ExternalLogin"
                                      asp-route-returnUrl="@Model.ReturnUrl"
                                      method="post">

                                    <div class="d-flex flex-wrap gap-3">

                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit"
                                                    class="btn auth-social-btn"
                                                    name="provider"
                                                    value="@provider.Name"
                                                    title="Log in using your @provider.DisplayName account">

                                                @provider.DisplayName

                                            </button>
                                        }

                                    </div>

                                </form>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}