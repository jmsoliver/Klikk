@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
}

<!-- ========================================
     AUTH PAGE
======================================== -->

<section class="auth-section">

    <div class="container">

        <div class="auth-wrapper">

            <div class="row g-0">

                <!-- LEFT SIDE -->

                <div class="col-lg-6">

                    <div class="auth-brand-side">

                        <span class="auth-badge">

                            Join Klikk ✨

                        </span>

                        <h1>

                            Start Shopping with <span>Klikk</span>

                        </h1>

                        <p>

                            Create your account and unlock
                            a faster, smarter, and more modern
                            ecommerce experience.

                        </p>

                        <div class="auth-features">

                            <div class="auth-feature-item">

                                <i class="bi bi-lightning-charge"></i>

                                <span>
                                    Seamless Shopping Experience
                                </span>

                            </div>

                            <div class="auth-feature-item">

                                <i class="bi bi-heart-fill"></i>

                                <span>
                                    Save Products to Wishlist
                                </span>

                            </div>

                            <div class="auth-feature-item">

                                <i class="bi bi-credit-card"></i>

                                <span>
                                    Secure Stripe Payments
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- RIGHT SIDE -->

                <div class="col-lg-6">

                    <div class="auth-form-side">

                        <div class="auth-form-wrapper">

                            <h2>

                                Create Account

                            </h2>

                            <p class="auth-subtitle">

                                Register below to start your Klikk journey.

                            </p>

                            <form id="registerForm"
                                  asp-route-returnUrl="@Model.ReturnUrl"
                                  method="post">

                                <div asp-validation-summary="ModelOnly"
                                     class="alert alert-danger"
                                     role="alert">
                                </div>

                                <!-- EMAIL -->
                                <!-- EMAIL -->

                                <div class="auth-input-group">

                                    <label asp-for="Input.Email">

                                        Email Address

                                    </label>

                                    <input asp-for="Input.Email"
                                           class="form-control auth-input"
                                           autocomplete="username"
                                           placeholder="name@example.com"
                                           required
                                           type="email"
                                           title="Enter a valid email address" />

                                    <span asp-validation-for="Input.Email"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- DELIVERY INFORMATION -->

                                <h5 class="mt-4 mb-3 fw-bold">
                                    Delivery Information
                                </h5>

                                <div class="row">

                                    <div class="col-12">

                                        <div class="auth-input-group">

                                            <label>

                                                Full Name

                                            </label>

                                            <input type="text"
                                                   class="form-control auth-input"
                                                   placeholder="Juan Dela Cruz"
                                                   required />

                                        </div>

                                    </div>

                                    <div class="col-12">

                                        <div class="auth-input-group">

                                            <label>

                                                Mobile Number

                                            </label>

                                            <input type="tel"
                                                   class="form-control auth-input"
                                                   placeholder="09XXXXXXXXX"
                                                   required />

                                        </div>

                                    </div>

                                    <div class="col-12">

                                        <div class="auth-input-group">

                                            <label>

                                                House No. / Street

                                            </label>

                                            <input type="text"
                                                   class="form-control auth-input"
                                                   placeholder="123 Mabini Street"
                                                   required />

                                        </div>

                                    </div>

                                    <div class="col-md-6">

                                        <div class="auth-input-group">

                                            <label>

                                                Barangay

                                            </label>

                                            <input type="text"
                                                   class="form-control auth-input"
                                                   placeholder="Barangay Alapan"
                                                   required />

                                        </div>

                                    </div>

                                    <div class="col-md-6">

                                        <div class="auth-input-group">

                                            <label>

                                                City / Municipality

                                            </label>

                                            <input type="text"
                                                   class="form-control auth-input"
                                                   placeholder="Imus"
                                                   required />

                                        </div>

                                    </div>

                                    <div class="col-md-6">

                                        <div class="auth-input-group">

                                            <label>

                                                Province

                                            </label>

                                            <input type="text"
                                                   class="form-control auth-input"
                                                   placeholder="Cavite"
                                                   required />

                                        </div>

                                    </div>

                                    <div class="col-md-6">

                                        <div class="auth-input-group">

                                            <label>

                                                ZIP Code

                                            </label>

                                            <input type="text"
                                                   class="form-control auth-input"
                                                   placeholder="4103"
                                                   required />

                                        </div>

                                    </div>

                                </div>

                                <!-- PASSWORD -->
                                <!-- PASSWORD -->

                                <div class="auth-input-group">

                                    <label asp-for="Input.Password">

                                        Password

                                    </label>

                                    <input asp-for="Input.Password"
                                           class="form-control auth-input"
                                           autocomplete="new-password"
                                           placeholder="Create a password"
                                           required
                                           minlength="8"
                                           pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$"
                                           title="Password must contain uppercase, lowercase, and a number." />

                                    <span asp-validation-for="Input.Password"
                                          class="text-danger">
                                    </span>

                                    <small class="text-muted">
                                        Minimum 8 characters with uppercase, lowercase, and number.
                                    </small>

                                </div>

                                <!-- CONFIRM PASSWORD -->

                                <div class="auth-input-group">

                                    <label asp-for="Input.ConfirmPassword">

                                        Confirm Password

                                    </label>

                                    <input asp-for="Input.ConfirmPassword"
                                           class="form-control auth-input"
                                           autocomplete="new-password"
                                           placeholder="Confirm your password" />

                                    <span asp-validation-for="Input.ConfirmPassword"
                                          class="text-danger">
                                    </span>

                                </div>

                                <!-- BUTTON -->

                                <button id="registerSubmit"
                                        type="submit"
                                        class="btn auth-submit-btn">

                                    Create Klikk Account

                                </button>

                                <!-- LINKS -->

                                <div class="auth-links">

                                    <a asp-page="./Login"
                                       asp-route-returnUrl="@Model.ReturnUrl">

                                        Already have an account?

                                    </a>

                                </div>

                            </form>

                            <!-- EXTERNAL LOGIN -->
                            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                            {
                                <div class="auth-divider">

                                    <span>

                                        OR REGISTER WITH

                                    </span>

                                </div>

                                <form id="external-account"
                                      asp-page="./ExternalLogin"
                                      asp-route-returnUrl="@Model.ReturnUrl"
                                      method="post">

                                    <div class="d-flex flex-wrap gap-3">

                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit"
                                                    class="btn auth-social-btn"
                                                    name="provider"
                                                    value="@provider.Name"
                                                    title="Register using your @provider.DisplayName account">

                                                @provider.DisplayName

                                            </button>
                                        }

                                    </div>

                                </form>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}